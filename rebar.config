{erl_opts, [debug_info, warnings_as_errors]}.

%% `livery` is declared as a dependency so it joins the build graph; the
%% local `_checkouts/livery` symlink overrides the source (no hex fetch for
%% livery itself). Its transitive deps (h1, h2, ...) are fetched from hex.
%% `gpb` is the protobuf runtime; messages are compiled from `proto/` by
%% rebar3_gpb_plugin at build time.
{deps, [
    {livery, "0.3.0"},
    {gpb, "5.0.0"}
]}.

%% Compile proto/*.proto -> src/*_pb.erl (maps mode) before erl compile.
{gpb_opts, [
    {i, "proto"},
    {module_name_suffix, "_pb"},
    {o_erl, "src"},
    {o_hrl, "include"},
    {strings_as_binaries, true},
    {maps, true},
    {maps_unset_optional, omitted},
    type_specs,
    {report_warnings, true}
]}.

{provider_hooks, [
    {pre, [
        {compile, {protobuf, compile}},
        {clean, {protobuf, clean}}
    ]}
]}.

{shell, [
    {apps, [livery_grpc]}
]}.

{cover_enabled, true}.
{cover_opts, [verbose]}.
{eunit_opts, [verbose]}.

{xref_checks, [
    undefined_function_calls,
    undefined_functions,
    locals_not_used,
    deprecated_function_calls
]}.

{dialyzer, [
    {warnings, [unmatched_returns, error_handling, unknown]},
    {plt_extra_apps, [livery, gpb, crypto, ssl, public_key]}
]}.

{project_plugins, [
    {erlfmt, "1.7.0"},
    {rebar3_lint, "4.1.1"},
    {rebar3_gpb_plugin, "3.0.1"},
    rebar3_ex_doc
]}.

{erlfmt, [
    write,
    {files, [
        "{src,include,test}/**/*.{hrl,erl,app.src}",
        "rebar.config"
    ]},
    %% Generated *_pb.erl files are not hand-edited; keep erlfmt off them.
    {exclude_files, ["src/*_pb.erl"]}
]}.

{ex_doc, [
    {source_url, <<"https://github.com/benoitc/livery_grpc">>},
    {main, <<"readme">>},
    {extras, [
        {"README.md", #{title => <<"Overview">>}},
        {"CHANGELOG.md", #{title => <<"Changelog">>}}
    ]}
]}.

{hex, [{doc, #{provider => ex_doc}}]}.

{elvis, [
    #{
        dirs => ["src"],
        filter => "*.erl",
        %% Generated protobuf modules do not follow the style rules.
        ignore => [],
        rules => [
            {elvis_style, no_macros, disable},
            {elvis_style, no_common_caveats_call, disable},
            {elvis_style, no_init_lists, disable},
            {elvis_style, param_pattern_matching, disable}
        ],
        ruleset => erl_files_strict
    },
    #{
        dirs => ["."],
        filter => "rebar.config",
        rules => [
            {elvis_project, no_branch_deps, disable}
        ],
        ruleset => rebar_config
    }
]}.

{profiles, [
    {test, [
        {erl_opts, [debug_info, nowarn_export_all, nowarn_missing_spec]},
        {deps, [{proper, "1.4.0"}]}
    ]}
]}.
