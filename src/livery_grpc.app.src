{application, livery_grpc, [
    {description, "gRPC for Erlang on the livery HTTP/2 stack: server and client"},
    {vsn, "0.1.0"},
    {registered, [livery_grpc_sup]},
    {mod, {livery_grpc_app, []}},
    {applications, [
        kernel,
        stdlib,
        crypto,
        ssl,
        gpb,
        livery
    ]},
    {env, []},
    {modules, []},
    {licenses, ["Apache-2.0"]},
    {links, [{"GitHub", "https://github.com/benoitc/livery_grpc"}]}
]}.
